# GitHub Configuration
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Supabase Public Keys (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Database Configuration (sensitive - never commit actual values)
SUPA_POSTGRES_DATABASE=postgres
SUPA_POSTGRES_HOST=xxxxxxxxxxxx.supabase.co
SUPA_POSTGRES_PASSWORD=your_postgres_password
SUPA_POSTGRES_PRISMA_URL=postgresql://postgres:password@xxxxxxxxxxxx.supabase.co:5432/postgres
SUPA_POSTGRES_URL=postgresql://postgres:password@xxxxxxxxxxxx.supabase.co:5432/postgres
SUPA_POSTGRES_URL_NON_POOLING=postgresql://postgres:password@xxxxxxxxxxxx.supabase.co:5432/postgres
SUPA_POSTGRES_USER=postgres

# Supabase Secret Keys (sensitive - server-side only)
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_settings
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
