# GitHub projects source
# If omitted, the app attempts to infer username from data/profile.json -> links.github
GITHUB_USERNAME=your-github-username

# Optional but recommended for higher GitHub API rate limits
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional: comma-separated repo names to prioritize in the portfolio projects view
# Example: notifications-platform,geo-search-api
GITHUB_FEATURED_REPOS=

# Optional: comma-separated repo names to exclude from portfolio projects view
# Example: sandbox-repo,old-experiment
GITHUB_EXCLUDED_REPOS=

# Optional: canonical site URL for metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
